# Copy to .env and adjust. Loaded by your shell or process manager—not read automatically by rag-core.

# --- Qdrant (docker compose up -d) ---
RAG_CORE_QDRANT_URL=http://127.0.0.1:6333
RAG_CORE_QDRANT_COLLECTION=rag_core_self_host

# --- No-key smoke (demo embeddings + ephemeral store) ---
# RAG_CORE_QDRANT_LOCATION=:memory:
# RAG_CORE_EMBEDDING_PROVIDER=demo
# RAG_CORE_EMBEDDING_MODEL=demo-dense-v1
# RAG_CORE_EMBEDDING_DIMENSIONS=64

# --- Production-like retrieval (requires provider API key) ---
RAG_CORE_EMBEDDING_PROVIDER=openai
RAG_CORE_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# Optional
# RAG_CORE_RERANKER_PROVIDER=none
